mod Top {
    incoming clk : Clock
    incoming reset : Bit on clk
    outgoing out : Word[8] on clk

    reg r : Word[8] on clk
    r <= mux(reset, 10w8, r + 1)

    mod buffer of Buffer {
        it.clk := clk
        it.inp := r
    }
    out := buffer.out
}

mod Buffer {
    incoming clk : Clock
    incoming inp : Word[8] on clk
    outgoing out : Word[8] on clk

    reg r : Word[8] on clk
    r <= inp
    out := r
}
