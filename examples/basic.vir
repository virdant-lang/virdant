export mod Top {
    incoming clock : Clock
    incoming inp : Bit on clock
    outgoing out : Bit on clock

    mod foo of Foo
    foo.clock := clock
    foo.inp := inp
    out := foo.inp
}

mod Foo {
    incoming clock : Clock
    incoming inp : Bit on clock
    outgoing out : Bit on clock

    reg r : Bit on clock

    out := r
    r <= r
}
