enum type MyEnum {
    Foo = 0w2
    Baz = 1
    Qux = 2
}

union type MyUnion {
    Foo()
    Bar(x : MyEnum)
}

mod Top {
    wire my_union : MyUnion async {
        it := @Bar(#Baz)
    }

    wire union_match : MyEnum async {
        unused it
        it := match my_union {
            case @Foo() => #Baz
            case @Bar(x) => x
        }
    }

    wire union_match_is_baz : Bit async {
        it := union_match == #Baz
        unused it
    }

    wire my_enum : MyEnum async
    my_enum := #Foo
    unused enum_match
    wire enum_match : Word[8] async
    enum_match :=
        match my_enum {
            case #Foo => 0
            case #Baz => 1
            case #Qux => 2
        }

    wire parity : Bit async
    unused parity
    parity :=
        match 2w2 {
            case 0 => false
            case 1 => true
            case 2 => false
            case 3 => true
        }
}
