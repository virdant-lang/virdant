mod Top {
    incoming clock : Clock
    incoming reset : Bit on clock
    outgoing out : Bit on clock

    reg val : Bit on clock {
        it <= mux(reset, false, !it)
    }

    mod led of LedDriver {
        it.clock := clock
        it.inp := val
        out := it.out
    }
}

ext mod LedDriver {
    incoming clock : Clock
    incoming inp : Bit on clock

    outgoing out : Bit on clock
}
