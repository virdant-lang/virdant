mod Top {
    incoming clock : Clock
    incoming reset : Bit on clock
    outgoing out : Word[8] on clock

    reg r : Word[8] on clock {
        it <= mux(reset, 10w8, it + 1)
    }

    mod buffer of Buffer {
        it.clock := clock
        it.inp := r
        out := it.out
    }
}

mod Buffer {
    incoming clock : Clock
    incoming inp : Word[8] on clock
    outgoing out : Word[8] on clock

    reg r : Word[8] on clock {
        it <= inp
        out := it
    }
}
