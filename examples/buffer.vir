mod Top {
    incoming clock : Clock
    incoming reset : Bit
    outgoing out : Word[8]

    reg r : Word[8] on clock {
        it <= if reset { 10w8 } else { it + 1 }
    }

    mod buffer of Buffer {
        it.clock := clock
        it.inp := r
        out := it.out
    }
}

mod Buffer {
    incoming clock : Clock
    incoming inp : Word[8]
    outgoing out : Word[8]

    reg r : Word[8] on clock {
        it <= inp
        out := it
    }
}
