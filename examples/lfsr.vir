mod Lfsr {
    incoming clock : Clock
    incoming reset : Bit
    outgoing out : Word[8]

    wire taps : Word[8]
    taps := 29w8

    reg r : Word[8] on clock
    r <= when {
        case reset => 255w8
        else => word(r[7..0], 0w1) ^ mux(feedback, taps, 0w8)
    }

    out := r

    wire feedback : Bit
    feedback := r[7]

    reg s : Word[4] on clock
    s <= mux(reset, 1, word(s[3..0], s[3]))
}
