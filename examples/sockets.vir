mod Top {
    mod core of Core
    mod memory of Memory

    memory.mem :=: core.mem
}

mod Core {
    client socket mem of Mem
    unused mem.data
    mem.addr := 0
}

mod Memory {
    server socket mem of Mem
    unused mem.addr
    mem.data := 10
}

socket Mem {
    cosi addr : Word[16]
    soci data : Word[8]
}
