mod Top {
    incoming clock : Clock

    mod core of Core
    mod memory of Memory

    memory.mem :=: core.mem
}

mod Core {
    client socket mem of Mem
    mem.addr := 0
}

mod Memory {
    server socket mem of Mem
    mem.data := 10
}

socket Mem {
    cosi addr : Word[16]
    ciso data : Word[8]
}
