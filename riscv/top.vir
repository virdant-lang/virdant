import alu;
import rf;
import ifetch;
import cpu;

export mod Top {
    incoming clock : Clock;
    incoming reset : Bit;
    outgoing fin : Bit;

    reg cycle : Word[32] on clock;
    cycle <= if reset { 0w32 } else { cycle + 1w32 };

    mod cpu of cpu::Cpu;
    cpu.clock := clock;
    cpu.reset := reset;
    cpu.cycle := cycle;

    fin := (cycle == 8w32);
}
