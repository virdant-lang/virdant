virir {
    package on_stmts {
        export mod Top {
            incoming clock : builtin::Clock;

            on (clock : builtin::Clock) {
                assert((1 : builtin::Bit));
                display("Test", (1 : builtin::Bit));
                fatal;
            }
        }
    }

    type builtin::Bit;
    type builtin::Clock;
}
