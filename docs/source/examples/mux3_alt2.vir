mod Mux3 {
    incoming a : Word[8]
    incoming b : Word[8]
    incoming c : Word[8]

    incoming select_a : Bit
    incoming select_b : Bit
    incoming select_c : Bit

    outgoing out : Word[8] {
        it := when {
            case select_a => a
            case select_b => b
            case select_c => c
            else => 0
        }
    }
}
