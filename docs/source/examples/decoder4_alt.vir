mod Decoder4 {
    incoming inp : Word[2]

    outgoing out : Word[4] {
        match inp {
            case 0 => {
                it := 0b0001
            }
            case 1 => {
                it := 0b0010
            }
            case 2 => {
                it := 0b0100
            }
            case 3 => {
                it := 0b1000
            }
        }
    }
}
