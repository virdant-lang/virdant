mod Top {
    incoming inp : Valid
    outgoing out : Word[8]

    out :=
        match inp {
            case @Invalid() => 0
            case @Valid(payload) => payload
        }

    wire another : Word[8]
    another :=
        match inp : Valid {
            case @Invalid() => 0
            case @Valid(payload) => payload
        }
}

union type Valid {
    Invalid()
    Valid(payload : Word[8])
}
