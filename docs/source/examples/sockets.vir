socket Mem {
    cosi addr : Word[16]
    ciso data : Word[8]
}

mod Core {
    client socket mem of Mem
    // mem.addr := ...

    mem.addr := 0
}

mod Memory {
    server socket mem of Mem
    // mem.data := ...
    mem.data := 0
}

mod Top {
    mod core of Core
    mod memory of Memory

    memory.mem :=: core.mem
}
