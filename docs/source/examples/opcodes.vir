enum type AluOp width 3 {
    and = 1
    or  = 2
    xor = 3
    add = 4
    sub = 5
}

mod Alu {
    incoming a : Word[8]
    incoming b : Word[8]
    incoming op : AluOp
    outgoing r : Word[8]

    r := match op {
        case #and => a & b
        case #or  => a | b
        case #xor => a ^ b
        case #add => a + b
        case #sub => a - b
    }
}
