mod Top {
    incoming clock : Clock
    incoming reset : Bit
    incoming inp : Word[8]
    outgoing max_seen : Word[8]

    reg max_seen_reg : Word[8] on clock

    // Compute the maximum of the current register value and the input
    wire current_max : Word[8]
    current_max := mux(max_seen_reg < inp, inp, max_seen_reg)

    max_seen_reg <= when {
        case reset => 0
        else => current_max
    }

    max_seen := max_seen_reg
}
