enum type State width 2 {
    On  = 1w2
    Off = 2w2
}

export mod Top {
    incoming clock : Clock
    incoming reset : Bit

    outgoing out : Bit

    reg state : State on clock
    when {
        case reset {
            state <= #Off
        }
        case state == #Off {
            state <= #On
        }
        else {
            state <= #Off
        }
    }

    match state {
        case #On {
            out := true
        }
        case #Off {
            out := false
        }
    }

    reg r : Bit on clock
    unused r

    when {
        case reset {
            r <= true
        }
        else {
            match #Off : State {
                case #On {
                    r <= false
                }
            }
        }
    }
}
