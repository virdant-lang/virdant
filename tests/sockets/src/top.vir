mod Top {
    mod core of Core
    mod memory of Memory

    memory.mem :=: core.mem
}

mod Core {
    client socket mem of Mem {
        it.addr := 8
        unused it.data
    }
}

mod Memory {
    server socket mem of Mem {
        it.data := 10
    }
    unused mem.addr
}

socket Mem {
    cosi addr : Word[16]
    ciso data : Word[8]
}
