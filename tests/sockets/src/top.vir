mod Top {
    mod core of Core
    mod memory of Memory

    memory.mem :=: core.mem
}

mod Core {
    master socket mem of Mem {
        it.addr := 8
        drop it.data
    }
}

mod Memory {
    slave socket mem of Mem {
        it.data := 10
    }
    drop mem.addr
}

socket Mem {
    mosi addr : Word[16]
    miso data : Word[8]
}
