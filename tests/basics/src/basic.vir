export mod Top {
    incoming clock : Clock;
    incoming reset : Bit;
    outgoing fin : Bit;

    fin := false;

    wire w : Bit;
    w := true;

    wire a : Bit;
    a := false;

    wire o : Word[8];
    o := 0w8 : Word[8];

    wire b : Word[4];
    b := 1w4 + 2w4;

    wire x : Word[4];
    x := 0b1010w4;

    wire y : Word[4];
    y := 0b0011w4;

    wire z : Word[8];
    z := zext(0x8w4);

    wire s : Word[8];
    s := sext(0x8w4);

    wire and : Word[8];
    and := 3w8 & 1w8;

    wire or : Word[8];
    or := 0w8 | 1w8;

    wire xor : Word[8];
    xor := 0w8 ^ 1w8;

    wire ascription : Word[4];
    ascription := 15 : Word[4];

    wire bit_and : Bit;
    bit_and := true && false;

    wire bit_or : Bit;
    bit_or := true || false;

    wire bit_xor : Bit;
    bit_xor := true ^^ false;

    on clock {
        assert(w);
        assert(!a);
        assert(w == true);
        assert(a == false);
        assert(w != a);

        assert(w && (!a));
        assert(w || a);
        assert(w ^^ a);
        assert(if w { true } else { false });
        assert(if a { false } else { true });

        assert(x == 0b1010w4);
        assert(y == 0b0011w4);
        assert(x != y);
        assert(x > y);
        assert(y < x);
        assert(x >= 0b1010w4);
        assert(y <= x);

        assert(x + y == 0b1101w4);
        assert(x - y == 0b0111w4);
        assert(~x == 0b0101w4);
        assert(-1w4 == 0b1111w4);

        assert(word(w : Bit) == 1w1);
        assert(word(w, y) == 0b10011w5);
        assert(word(w, y)[4]);
        assert(word(w, y)[3] == false);
        assert(word(w, y)[2] == false);
        assert(word(w, y)[1]);
        assert(word(w, y)[0]);

        assert(z == 0x08w8);
        assert(z[7] == false);
        assert(s == 0xf8w8);
        assert(s[7] == true);

        assert((if w { x } else { y }) : Word[4] == x);
        assert((if a { x } else { y }) : Word[4] == y);

        assert(!bit_and);
        assert(bit_or);
        assert(bit_xor);

        assert(or == 1);
        assert(and == 1);
        assert(xor == 1);

        assert(ascription == 15);
    };
}
