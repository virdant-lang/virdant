export mod Top {
    incoming clock : Clock;
    incoming reset : Bit;
    outgoing fin : Bit;

    fin := false;

    wire w : Bit;
    w := true;

    wire a : Bit;
    a := false;

    wire o : Word[8];
    o := 0w8 : Word[8];

    wire b : Word[4];
    b := 1w4 + 2w4;

    wire x : Word[4];
    x := 0b1010w4;

    wire y : Word[4];
    y := 0b0011w4;

    wire z : Word[8];
    z := zext(0x8w4);

    wire s : Word[8];
    s := sext(0x8w4);

    wire and_ : Word[8];
    and_ := 0w8 & 1w8;

    wire or_ : Word[8];
    or_ := 0w8 | 1w8;

    wire xor_ : Word[8];
    xor_ := 0w8 ^ 1w8;

//    wire bit_and_ : Bit;
//    bit_and_ := 0w8 && 1w8;
//
//    wire bit_or_ : Bit;
//    bit_or_ := 0w8 || 1w8;
//
//    wire bit_xor_ : Bit;
//    bit_xor_ := 0w8 ^^ 1w8;

    on clock {
        assert(w);
        assert(!a);
        assert(w == true);
        assert(a == false);
        assert(w != a);

        assert(w && (!a));
        assert(w || a);
        assert(w ^^ a);
        assert(if w { true } else { false });
        assert(if a { false } else { true });

        assert(x == 0b1010w4);
        assert(y == 0b0011w4);
        assert(x != y);
        assert(x > y);
        assert(y < x);
        assert(x >= 0b1010w4);
        assert(y <= x);

        assert(x + y == 0b1101w4);
        assert(x - y == 0b0111w4);
        assert(~x == 0b0101w4);
        assert(-1w4 == 0b1111w4);

        assert(word(w : Bit) == 1w1);
        assert(word(w, y) == 0b10011w5);
        assert(word(w, y)[4]);
        assert(word(w, y)[3] == false);
        assert(word(w, y)[2] == false);
        assert(word(w, y)[1]);
        assert(word(w, y)[0]);

        assert(z == 0x08w8);
        assert(z[7] == false);
        assert(s == 0xf8w8);
        assert(s[7] == true);

        assert((if w { x } else { y }) : Word[4] == x);
        assert((if a { x } else { y }) : Word[4] == y);

        if true {
            display("Hello", true);
        };
        finish;
    };
}
