export mod Top {
    incoming clock : Clock;
    incoming reset : Bit;
    outgoing fin : Bit;

    fin := false;

    wire w : Bit;
    w := true;

    wire a : Bit;
    a := false;

    wire o : Word[8];
    o := 0w8 : Word[8];

    wire b : Word[4];
    b := 1w4 + 2w4;

    wire x : Word[4];
    x := 0b1010w4;

    wire y : Word[4];
    y := 0b0011w4;

    wire z : Word[8];
    z := zext(0x8w4);

    wire s : Word[8];
    s := sext(0x8w4);

    wire and : Word[8];
    and := 3w8 & 1w8;

    wire or : Word[8];
    or := 0w8 | 1w8;

    wire xor : Word[8];
    xor := 0w8 ^ 1w8;

    wire ascription : Word[4];
    ascription := 15 : Word[4];

    wire bit_and : Bit;
    bit_and := true && false;

    wire bit_or : Bit;
    bit_or := true || false;

    wire bit_xor : Bit;
    bit_xor := true ^^ false;

}
