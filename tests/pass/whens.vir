// CHECK: Check OK
mod When {
    incoming clock : Clock
    incoming inp1 : Bit

    outgoing out1 : Bit {
        when {
            case inp1 {
                it := true
            }
            else {
                it := false
            }
        }
    }

    reg r : Bit on clock {
        when {
            case inp1 {
                it <= true
            }
        }

        unused it
    }

    incoming inp2 : Bit

    outgoing out2 : Bit {
        it := when {
            case inp2 => false
            else => true
        }
    }
}

mod Fine {
    incoming clock : Clock
    incoming reset : Reset

    reg start : Word[3] on clock {
        it <= when {
            case reset => 0
            else => ?
        }
    }
}
