//! ALU and barrel shifter modules.
//!
//! This package provides the main arithmetic-logic unit (Alu) that
//! executes all RV32I ALU operations, and a 32-bit barrel shifter (Shifter)
//! that handles SLL, SRL, and SRA in a single cycle.

//> ALU module.
//>
//> Performs arithmetic (add, sub), logical (and, or, xor, clear),
//> comparison (eq, neq, lt, gte, ltu, gteu), zero, pass-through,
//> and shift operations as directed by `AluOpcode`.
mod Alu {
    //> First ALU operand (typically rs1, PC, or CSR data).
    incoming a : Word[32] async
    //> Second ALU operand (typically rs2 or immediate).
    incoming b : Word[32] async
    //> ALU result.
    outgoing z : Word[32] async

    //> ALU operation selector (see `opcode::AluOpcode`).
    incoming op : AluOpcode async

    //> Barrel shifter sub-module used for SLL, SRL, and SRA.
    mod shifter of Shifter {
        it.a      := a
        it.amount := b[5..0]
        it.dir    := match op {
            case #Sll => #ShiftLeftLogical
            case #Srl => #ShiftRightLogical
            case #Sra => #ShiftRightArithmetic
            else => dontcare
        }
    }

    wire adder : Word[32] async {
        it := a + (match op {
            case #Add => b
            case #Sub => ~b + 1
            else => dontcare
        })
    }

    // Main ALU output: result selected by `op`.
    z := match op {
        case #Add => adder
        case #Sub => adder
        case #And => a & b
        case #Or  => a | b
        case #Xor => a ^ b
        case #Eq  => zext(a == b)
        case #Neq => zext(a != b)
        case #Lt  => mux(a[31] ^ b[31], zext(a[31]), zext(a < b))
        case #Gte => mux(a[31] ^ b[31], zext(b[31]), zext(a >= b))
        case #Zero => 0
        case #Ltu => zext(a < b)
        case #Gteu => zext(a >= b)
        case #Clear => a & (~b)
        case #PassA => a
        case #Sll => shifter.z
        case #Srl => shifter.z
        case #Sra => shifter.z
    }
}

//> Barrel-shift direction selector.
//>
//> Specifies the direction for the Shifter module.
enum type ShiftDirection {
    //> Shift left logical (SLL).
    ShiftLeftLogical     = 0b001w3
    //> Shift right logical (SRL).
    ShiftRightLogical    = 0b010
    //> Shift right arithmetic (SRA, sign-extending).
    ShiftRightArithmetic = 0b100
}

//> 32-bit barrel shifter.
//>
//> Implements SLL, SRL, and SRA in a single cycle using a logarithmic
//> shift network (five stages: 1, 2, 4, 8, 16).
mod Shifter {
    //> Shift direction (left logical, right logical, right arithmetic).
    incoming dir : ShiftDirection async
    //> Value to shift.
    incoming a : Word[32] async
    //> Shift amount (0–31).
    incoming amount : Word[5] async
    //> Shifted result.
    outgoing z : Word[32] async

    // TODO; This could be written with let blocks.

    //> Stage 1: shift left by 1.
    wire sll_1 : Word[32] async
    sll_1 := mux(amount[0], word(a[31..0], 0w1), a)

    //> Stage 2: shift left by 2.
    wire sll_2 : Word[32] async
    sll_2 := mux(amount[1], word(sll_1[30..0], 0w2), sll_1)

    //> Stage 4: shift left by 4.
    wire sll_4 : Word[32] async
    sll_4 := mux(amount[2], word(sll_2[28..0], 0w4), sll_2)

    //> Stage 8: shift left by 8.
    wire sll_8 : Word[32] async
    sll_8 := mux(amount[3], word(sll_4[24..0], 0w8), sll_4)

    //> Stage 16: shift left by 16.
    wire sll_16 : Word[32] async
    sll_16 := mux(amount[4], word(sll_8[16..0], 0w16), sll_8)

    //> Stage 1: shift right logical by 1.
    wire srl_1 : Word[32] async
    srl_1 := mux(amount[0], zext(a[32..1]), a)

    //> Stage 2: shift right logical by 2.
    wire srl_2 : Word[32] async
    srl_2 := mux(amount[1], zext(srl_1[32..2]), srl_1)

    //> Stage 4: shift right logical by 4.
    wire srl_4 : Word[32] async
    srl_4 := mux(amount[2], zext(srl_2[32..4]), srl_2)

    //> Stage 8: shift right logical by 8.
    wire srl_8 : Word[32] async
    srl_8 := mux(amount[3], zext(srl_4[32..8]), srl_4)

    //> Stage 16: shift right logical by 16.
    wire srl_16 : Word[32] async
    srl_16 := mux(amount[4], zext(srl_8[32..16]), srl_8)

    //> Stage 1: shift right arithmetic by 1 (sign-extending).
    wire sra_1 : Word[32] async
    sra_1 := mux(amount[0], sext(a[32..1]), a)

    //> Stage 2: shift right arithmetic by 2.
    wire sra_2 : Word[32] async
    sra_2 := mux(amount[1], sext(sra_1[32..2]), sra_1)

    //> Stage 4: shift right arithmetic by 4.
    wire sra_4 : Word[32] async
    sra_4 := mux(amount[2], sext(sra_2[32..4]), sra_2)

    //> Stage 8: shift right arithmetic by 8.
    wire sra_8 : Word[32] async
    sra_8 := mux(amount[3], sext(sra_4[32..8]), sra_4)

    //> Stage 16: shift right arithmetic by 16.
    wire sra_16 : Word[32] async
    sra_16 := mux(amount[4], sext(sra_8[32..16]), sra_8)

    // Final shifted output selected by `dir`.
    z := match dir {
        case #ShiftLeftLogical => sll_16
        case #ShiftRightLogical => srl_16
        case #ShiftRightArithmetic => sra_16
    }
}

enum type AluOpcode {
    //> Zero result (used for JAL/JALR address generation).
    Zero  = 0w8
    //> Addition (ADD, ADDI, AUIPC, LOAD/STORE address).
    Add   = 1
    //> Subtraction (SUB).
    Sub   = 2
    //> Bitwise AND (AND, ANDI).
    And   = 3
    //> Bitwise OR (OR, ORI).
    Or    = 4
    //> Bitwise XOR (XOR, XORI).
    Xor   = 5
    //> Signed equal-to-zero test (BEQ).
    Eq    = 6
    //> Signed not-equal-to-zero test (BNE).
    Neq   = 7
    //> Signed less-than (SLT, BLT).
    Lt    = 8
    //> Signed greater-than-or-equal (BGE).
    Gte   = 9
    //> Unsigned less-than (SLTU, BLTU).
    Ltu   = 10
    //> Unsigned greater-than-or-equal (BGEU).
    Gteu  = 11
    //> Shift left logical (SLL, SLLI).
    Sll   = 12
    //> Bit clear: a & ~b (CSRRC).
    Clear = 13
    //> Pass A through unchanged (CSRRW, CSRRWI).
    PassA = 14
    //> Shift right logical (SRL, SRLI).
    Srl   = 15
    //> Shift right arithmetic (SRA, SRAI).
    Sra   = 16
}
