union type State {
    Idle()
    Running(x : Word[8], y : Word[8])
    Done(result : Word[8])
}

export mod Top {
    incoming clock : Clock
    incoming reset : Bit on clock

    incoming x : Word[8] on clock
    incoming y : Word[8] on clock
    incoming fire : Bit on clock

    outgoing result : Word[8] on clock
    outgoing valid  : Bit on clock

    mod gcd of Gcd {
        it.reset := reset
        it.clock := clock
        it.x := x
        it.y := y
        it.fire := fire
        result := it.result
        valid := it.valid
    }
}

mod Gcd {
    incoming clock : Clock
    incoming reset : Bit on clock
    incoming x : Word[8] on clock
    incoming y : Word[8] on clock
    incoming fire : Bit on clock
    outgoing result : Word[8] on clock
    outgoing valid: Bit on clock

    reg state : State on clock {
        when {
            case reset {
                it <= @Idle()
            }
            else {
                it <= match it : State {
                    case @Idle() => mux(fire, @Running(x, y), @Idle())
                    case @Running(x, y) =>
                        mux(y == 0, @Done(x),
                        mux(x < y, @Running(y - x, x),
                        @Running(x - y, y)))
                    case @Done(result) => @Idle()
                }
            }
        }
    }

    match state {
        case @Done(r) {
            result := r
            valid := true
        }
        else {
            result := 0
            valid := false
        }
    }
}
