union type State {
    Idle()
    Running(x : Word[8], y : Word[8])
    Done(result : Word[8])
}

export mod Top {
    incoming clock : Clock
    incoming reset : Bit

    incoming x : Word[8]
    incoming y : Word[8]
    incoming fire : Bit

    outgoing result : Word[8]
    outgoing valid  : Bit

    mod gcd of Gcd {
        it.reset := reset
        it.clock := clock
        it.x := x
        it.y := y
        it.fire := fire
        result := it.result
        valid := it.valid
    }
}

mod Gcd {
    incoming clock : Clock
    incoming reset : Bit
    incoming x : Word[8]
    incoming y : Word[8]
    incoming fire : Bit
    outgoing result : Word[8]
    outgoing valid: Bit

    reg state : State on clock {
        if reset {
            it <= @Idle()
        } else {
            it <= match it : State {
                case @Idle() => if fire {
                    @Running(x, y)
                } else {
                    @Idle()
                }
                case @Running(x, y) =>
                    if y == 0 {
                        @Done(x)
                    } else if x < y {
                        @Running(y - x, x)
                    } else {
                        @Running(x - y, y)
                    }
                case @Done(result) => @Idle()
            }
        }
    }

    match state {
        case @Done(r) => {
            result := r
            valid := true
        }
        else => {
            result := 0
            valid := false
        }
    }
}
