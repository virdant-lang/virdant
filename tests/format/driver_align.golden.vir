// Driver alignment with :=, <=, :=:
mod Alignment {
    incoming a   : Word[8] async
    incoming bb  : Word[8] async
    incoming ccc : Word[8] async
    outgoing x   : Word[8] async
    outgoing yy  : Word[8] async
    outgoing zzz : Word[8] async

    a   := 1
    bb  := 2
    ccc := 3

    x   <= a
    yy  <= bb
    zzz <= ccc

    a   :=: x
    bb  :=: yy
    ccc :=: zzz
}
