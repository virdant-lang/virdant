// Nested braces: if/else and match
mod Nested {
    incoming cond   : Bit async
    incoming data   : Word[8] async
    outgoing result : Word[8] async

    result := mux(cond, data, 0w8)

    outgoing chosen : Word[8] async
    chosen := match data {
        case 0 => 1
        case 1 => 2
        case 2 => 3
    }
}
