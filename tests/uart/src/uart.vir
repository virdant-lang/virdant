export mod Top {
    incoming clock      : Clock // 12MHz
    incoming reset      : Bit on clock
    outgoing fin        : Bit on clock
    fin := cycle == 150000w32
    mod sender of UartSender {
        unused it.ready
        unused it.uart_tx
    }
    sender.clock := clock
    sender.reset := reset
    sender.data := 65w8
    sender.data_valid := true
    reg cycle : Word[32] on clock
    cycle <= mux(reset, 0w32, cycle + 1w32)
}

mod UartSender {
    incoming clock      : Clock // 12MHz
    incoming reset      : Bit on clock
    incoming data       : Word[8] on clock
    incoming data_valid : Bit on clock
    outgoing ready      : Bit on clock
    outgoing uart_tx    : Bit on clock

    reg uart_tx_reg : Bit on clock
    uart_tx := uart_tx_reg

    reg latched_data : Word[8] on clock

//    reg state : UartState on clock

    // States:
    //   0b00 = @Idle
    //   0b01 = @Start
    //   0b10 = @Bit
    //   0b11 = @Stop
    reg state  : Word[2] on clock
    reg pulse  : Word[11] on clock
    reg bitnum : Word[3] on clock

    ready := state == 0w2

    state <= mux(reset, 0w2, // @Idle
        mux(state == 0w2, mux(data_valid, 1w2, 0w2), // @Idle
        mux(state == 1w2, mux(pulse == 0w11, 2w2, 1w2), // @Start
        mux(state == 2w2, mux(pulse == 0w11, mux(bitnum < 7w3, 2w2, 3w2), 2w2), // @Bit
        mux(pulse == 0w11, 0w2, 3w2))))) // @Stop

    pulse <= mux(reset, 0w11,
        mux(state == 0w2, mux(data_valid, 1250w11, 0w11), // @Idle
        mux(state == 1w2, mux(pulse == 0w11, 1250w11, pulse - 1), // @Start
        mux(state == 2w2, mux(pulse == 0w11, 1250w11, pulse - 1), // @Bit
        mux(pulse == 0w11, 0w11, pulse - 1))))) // @Stop

    bitnum <= mux(reset, 0w3,
        mux(state == 1w2, mux(pulse == 0w11, 0w3, bitnum), // @Start
        mux(state == 2w2, mux(pulse == 0w11, mux(bitnum < 7w3, bitnum + 1, bitnum), bitnum), // @Bit
        bitnum)))

    latched_data <= mux(state == 0w2, mux(data_valid, data, latched_data), latched_data)

    uart_tx_reg <= mux(reset, true,
        mux(state == 0w2, true, // @Idle
        mux(state == 1w2, false, // @Start
        mux(state == 2w2, // @Bit
            mux(bitnum == 0w3, latched_data[0],
            mux(bitnum == 1w3, latched_data[1],
            mux(bitnum == 2w3, latched_data[2],
            mux(bitnum == 3w3, latched_data[3],
            mux(bitnum == 4w3, latched_data[4],
            mux(bitnum == 5w3, latched_data[5],
            mux(bitnum == 6w3, latched_data[6],
            latched_data[7]))))))),
        true)))) // @Stop
}
