export mod Top {
    incoming clock      : Clock // 12MHz
    incoming reset      : Bit
    outgoing fin        : Bit
    fin := cycle == 150000w32
    mod sender of UartSender {
        unused it.ready
        unused it.uart_tx
    }
    sender.clock := clock
    sender.reset := reset
    sender.data := 65w8
    sender.data_valid := true
    reg cycle : Word[32] on clock
    cycle <= when { case reset => 0w32  else => cycle + 1w32 }
}

mod UartSender {
    incoming clock      : Clock // 12MHz
    incoming reset      : Bit
    incoming data       : Word[8]
    incoming data_valid : Bit
    outgoing ready      : Bit
    outgoing uart_tx    : Bit

    reg uart_tx_reg : Bit on clock
    uart_tx := uart_tx_reg

    reg latched_data : Word[8] on clock

//    reg state : UartState on clock

    // States:
    //   0b00 = @Idle
    //   0b01 = @Start
    //   0b10 = @Bit
    //   0b11 = @Stop
    reg state  : Word[2] on clock
    reg pulse  : Word[11] on clock
    reg bitnum : Word[3] on clock

    ready := state == 0w2

    state <= if reset {
        0w2 // @Idle
    } else if state == 0w2 { // @Idle
        if data_valid {
            1w2 // @Start
        } else {
            0w2 // @Idle
        }
    } else if state == 1w2 { // @Start
        if pulse == 0w11 {
            2w2 // @Bit
        } else {
            1w2 // @Start
        }
    } else if state == 2w2 { // @Bit
        if pulse == 0w11 {
            if bitnum < 7w3 {
                2w2 // @Bit
            } else {
                3w2 // @Stop
            }
        } else {
            2w2 // @Bit
        }
    } else { // @Stop
        if pulse == 0w11 {
            0w2 // @Idle
        } else {
            3w2 // @Stop
        }
    }

    pulse <= if reset {
        0w11
    } else if state == 0w2 { // @Idle
        if data_valid {
            1250w11 // loading for Start state
        } else {
            0w11
        }
    } else if state == 1w2 { // @Start
        if pulse == 0w11 {
            1250w11 // loading for Bit state
        } else {
            pulse - 1
        }
    } else if state == 2w2 { // @Bit
        if pulse == 0w11 {
            1250w11 // loading for next Bit or Stop state
        } else {
            pulse - 1
        }
    } else { // @Stop
        if pulse == 0w11 {
            0w11
        } else {
            pulse - 1
        }
    }

    bitnum <= if reset {
        0w3
    } else if state == 1w2 { // @Start
        if pulse == 0w11 {
            0w3 // entering Bit state, start at bit 0
        } else {
            bitnum
        }
    } else if state == 2w2 { // @Bit
        if pulse == 0w11 {
            if bitnum < 7w3 {
                bitnum + 1
            } else {
                bitnum
            }
        } else {
            bitnum
        }
    } else {
        bitnum
    }

    latched_data <=
        if state == 0w2 { // @Idle
            if data_valid {
                data
            } else {
                latched_data
            }
        } else {
            latched_data
        }

    uart_tx_reg <= if reset {
        true
    } else if state == 0w2 { // @Idle
        true
    } else if state == 1w2 { // @Start
        false
    } else if state == 2w2 { // @Bit
        if bitnum == 0w3 {
            latched_data[0]
        } else if bitnum == 1w3 {
            latched_data[1]
        } else if bitnum == 2w3 {
            latched_data[2]
        } else if bitnum == 3w3 {
            latched_data[3]
        } else if bitnum == 4w3 {
            latched_data[4]
        } else if bitnum == 5w3 {
            latched_data[5]
        } else if bitnum == 6w3 {
            latched_data[6]
        } else {
            latched_data[7]
        }
    } else { // @Stop
        true
    }
}
