// Tests for MultipleDrivers and DriverForSink.

// Driving the same outgoing port twice in the same module.
mod TwoDrivers {
    outgoing out : Bit
    // CHECK: Multiple drivers for out
    out := true
    // CHECK: Multiple drivers for out
    out := false
}

mod NoDrivers {
    // CHECK: No drivers for out
    outgoing out : Bit
}

// Socket used to test DriverForSink from both sides.
socket Chan {
    cosi req : Word[8]
    soci ack : Bit
}

// A client drives cosi (req) — that is correct.
// But it also drives soci (ack) — soci is a source for the client, not a sink.
mod BadClient {
    client socket ch of Chan
    ch.req := 0
    // CHECK: Driver for sink ch.ack
    ch.ack := true
}

// A server drives soci (ack) — that is correct.
// But it also drives cosi (req) — cosi is a source for the server, not a sink.
mod BadServer {
    server socket ch of Chan
    ch.ack := true
    // CHECK: Driver for sink ch.req
    ch.req := 0
}

// A module with exactly one driver per outgoing port — no MultipleDrivers.
mod SingleDriver {
    outgoing a : Bit
    outgoing b : Bit
    // CHECK-NOT: Multiple drivers
    a := true
    b := false
}

mod DriverTypes {
    incoming clock : Clock

    wire a : Bit
    // CHECK-NOT: Wrong driver type for a
    a := true

    reg b : Bit on clock
    // CHECK-NOT: Wrong driver type for b
    b <= true

    wire c : Bit
    // CHECK: Wrong driver type for c
    c <= true

    // CHECK: Wrong driver type for d
    reg d : Bit on clock
    d := true
}

mod DriversForInternalPorts {
    // CHECK: No drivers for e.inp
    mod e of Ext

    // CHECK: No drivers for i.inp
    mod i of Int
}

ext mod Ext {
    incoming inp : Bit
    outgoing out : Bit
}

mod Int {
    incoming inp : Bit
    outgoing out : Bit

    out := inp
}

// A properly-wired client and server, used to test socket NoDrivers below.
mod GoodClient {
    client socket ch of Chan
    ch.req := 0
}

mod GoodServer {
    server socket ch of Chan
    ch.ack := true
}

// Without :=:, the sink channels of each socket are left undriven.
mod MissingSocketConnect {
    mod p of GoodClient
    mod q of GoodServer
    // CHECK: No drivers for p.ch.ack
    // CHECK: No drivers for q.ch.req
}

mod TwoDriversAcrossSections {
    incoming clock : Clock
    incoming reset : Bit
    outgoing out  : Bit

    when {
        case reset {
            out := true
        }
        else {
            out := false
        }
    }

    reg r : Bit on clock

    when {
        case reset {
            r <= true
        }
    }

    when {
        case !reset {
            // CHECK: Multiple drivers for r
            r <= false
        }
    }

    // CHECK: Multiple drivers for s
    reg s : Bit on clock
    s <= true

    when {
        case reset {
            s <= false
        }
    }

    // CHECK: Multiple drivers for t
    wire t : Bit
    t := true

    when {
        case reset {
            t := false
        }
    }

    wire u : Bit
    u := false

    match #On : Status {
        case #On {
        }
        else {
            u := true
        }
    }
}

enum type Status {
    On = 1w2
    Off = 2
}

// CHECK: Check failed
