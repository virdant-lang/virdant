enum type Opcode width 4 {
    Add = 1;
    Sub = 2;
    And = 4;
    Or  = 8;
}

export mod Top {
    incoming opcode_bits : Word[4];
    incoming x : Word[8];
    incoming y : Word[8];

    outgoing out : Word[8];

    wire opcode : Opcode;
    opcode := cast(opcode_bits);

    out := match opcode {
        #Add => x + y;
        #Sub => x - y;
        #And => x & y;
        #Or  => x | y;
    };
}
