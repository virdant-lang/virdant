enum type Opcode {
    Add = 1w4
    Sub = 2
    And = 4
    Or  = 8
}

struct type Color {
    red : Word[8]
    green : Word[8]
    blue : Word[8]
}

export mod Top {
    incoming opcode_bits : Word[4] async
    incoming x : Word[8] async
    incoming y : Word[8] async

    outgoing out : Word[8] async
    outgoing red : Word[8] async

    wire color : Color async

    wire opcode : Opcode async
    opcode := cast(opcode_bits)

    out := match opcode {
        case #Add => x + y
        case #Sub => x - y
        case #And => x & y
        case #Or  => x | y
    }

    color := ${
        red = 0,
        green = 128,
        blue = 255,
    }

    red := color->green
}
