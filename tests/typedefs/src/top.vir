enum type Opcode width 4 {
    Add = 1;
    Sub = 2;
    And = 4;
    Or  = 8;
}

struct type Color {
    red : Word[8];
    green : Word[8];
    blue : Word[8];
}

export mod Top {
    incoming opcode_bits : Word[4]
    incoming x : Word[8]
    incoming y : Word[8]

    outgoing out : Word[8]
    outgoing red : Word[8]

    wire color : Color

    wire opcode : Opcode
    opcode := cast(opcode_bits)

    out := match opcode {
        case #Add => x + y
        case #Sub => x - y
        case #And => x & y
        case #Or  => x | y
    }

    color := ${
        red = 0,
        green = 128,
        blue = 255,
    }

    red := color->green
}
