//! This is a package-level docstring for the virdoc test.
//! It demonstrates how package-level documentation works.

//> Top module with both counter and blinking LED logic.
//> It also shows how item-level docstrings appear in the docs.
mod Top {
    incoming clock : Clock

    outgoing led : Bit

    reg counter : Word[32] on clock
    counter <= counter + 1

    led := counter[21]
}
