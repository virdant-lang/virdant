<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% block title %}Virdant Project{% endblock %}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,400;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Fira+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="{{ style_href }}style.css">
{% block head_extra %}{% endblock %}
</head>
<body>
<div class="layout">

<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <a href="{{ style_href }}index.html" class="sidebar-logo">
      <span class="sidebar-logo-text">Virdant</span>
    </a>
  </div>

  <div class="sidebar-search">
    <input type="search" id="search-input"
           placeholder="Filter items..."
           autocomplete="off">
  </div>

  <nav class="sidebar-nav" id="sidebar-nav">
    <ul class="sidebar-tree">
      {% for pkg in all_packages %}
      <li class="package-group">
        <button class="package-toggle"
                aria-expanded="{% if pkg.is_active %}true{% else %}false{% endif %}">
          {{ pkg.name }}
        </button>
        <ul class="package-items"
            style="display: {% if pkg.is_active %}block{% else %}none{% endif %}">
          {% for item in pkg.items %}
          <li>
            <a href="{{ style_href }}{{ pkg.name }}/{{ item.filename }}"
               class="{% if item.is_current %}current{% endif %}">
              <span class="kind-dot kind-dot-{{ item.kind_label }}"></span>
              {{ item.name }}
            </a>
          </li>
          {% endfor %}
        </ul>
      </li>
      {% endfor %}
    </ul>
  </nav>
</aside>

<button class="sidebar-toggle" id="sidebar-toggle"
        aria-label="Toggle sidebar">&#9776;</button>

<main class="content">
  <header class="content-header">
    <nav class="breadcrumbs">{% block breadcrumbs %}{% endblock %}</nav>
    <button class="theme-toggle" id="theme-toggle"
            aria-label="Toggle dark mode">&#9790;</button>
  </header>

  <div class="content-body">
    {% block content %}{% endblock %}
  </div>

  <footer class="content-footer">
    <p>Generated by <a href="https://virdant.org">Virdant</a></p>
  </footer>
</main>

</div>

<script>
(function() {
  // Theme
  var stored = localStorage.getItem('virdant-theme');
  var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  var theme = stored || (prefersDark ? 'dark' : 'light');
  document.documentElement.setAttribute('data-theme', theme);
  var toggleBtn = document.getElementById('theme-toggle');
  toggleBtn.textContent = theme === 'dark' ? '\u2600' : '\u263E';

  toggleBtn.addEventListener('click', function() {
    var current = document.documentElement.getAttribute('data-theme');
    var next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('virdant-theme', next);
    this.textContent = next === 'dark' ? '\u2600' : '\u263E';
  });

  // Sidebar toggle (mobile)
  document.getElementById('sidebar-toggle').addEventListener('click', function() {
    document.getElementById('sidebar').classList.toggle('open');
  });

  // Package toggle (expand/collapse)
  var toggles = document.querySelectorAll('.package-toggle');
  for (var t = 0; t < toggles.length; t++) {
    toggles[t].addEventListener('click', function() {
      var expanded = this.getAttribute('aria-expanded') === 'true';
      this.setAttribute('aria-expanded', !expanded);
      var items = this.nextElementSibling;
      if (items) {
        items.style.display = expanded ? 'none' : 'block';
      }
    });
  }

  // Client-side search filter
  document.getElementById('search-input').addEventListener('input', function() {
    var q = this.value.toLowerCase();
    var items = document.querySelectorAll('#sidebar-nav .package-items a');
    for (var i = 0; i < items.length; i++) {
      items[i].style.display = items[i].textContent.toLowerCase().includes(q) ? '' : 'none';
    }
    // Also show package groups that have visible items
    var groups = document.querySelectorAll('.package-group');
    for (var j = 0; j < groups.length; j++) {
      var group = groups[j];
      var visibleItems = group.querySelectorAll('.package-items a[style*=\"display: block\"], .package-items a:not([style])');
      var hasVisible = false;
      for (var k = 0; k < visibleItems.length; k++) {
        if (visibleItems[k].style.display !== 'none') {
          hasVisible = true;
          break;
        }
      }
      group.style.display = hasVisible ? '' : 'none';
    }
  });
})();
</script>

{% block scripts %}{% endblock %}
</body>
</html>